# Django
SECRET_KEY=change-me
DEBUG=0
REQUIRE_AUTH=1
ALLOWED_HOSTS=api.seudominio.com
CORS_ALLOWED_ORIGINS=https://app.seudominio.com
CSRF_TRUSTED_ORIGINS=https://app.seudominio.com
DJANGO_LOG_LEVEL=INFO

# Database (managed Postgres - Supabase/Neon/RDS)
# IMPORTANT: if password has @, :, /, ?, #, use URL-encoded password.
DATABASE_URL=postgresql://USER:PASSWORD_URL_ENCODED@HOST:5432/DBNAME?sslmode=require
DB_CONN_MAX_AGE=300
DB_CONNECT_TIMEOUT=8

# Redis (managed Redis)
REDIS_URL=rediss://default:PASSWORD@HOST:6379

# Optional app defaults
STORE_NAME=Sorveteria POS
SECURE_SSL_REDIRECT=1
