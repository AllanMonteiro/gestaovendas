# Root env example for local/dev scripts

# Frontend host
VITE_API_URL=http://127.0.0.1:8000
VITE_WS_URL=ws://127.0.0.1:8000

# Backend
SECRET_KEY=dev-secret
DEBUG=1
REQUIRE_AUTH=0
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000
DATABASE_URL=postgresql://sorveteria:sorveteria@127.0.0.1:5432/sorveteria_pos
REDIS_URL=redis://127.0.0.1:6379/0

# Optional domains for old compose/Caddy flow
API_DOMAIN=api.seudominio.com
APP_DOMAIN=app.seudominio.com
