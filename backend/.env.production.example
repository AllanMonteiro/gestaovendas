# 🚀 MASTER PRODUCTION ENVIRONMENT VARIABLES
# Copy these to your Render Dashboard (Settings -> Environment Variables)

# 1. Django Core
DJANGO_SECRET_KEY=your_very_secret_key_here
DEBUG=0
DJANGO_ALLOWED_HOSTS=.onrender.com
CORS_ALLOWED_ORIGINS=https://gestaovendas-frontend.onrender.com
CSRF_TRUSTED_ORIGINS=https://gestaovendas-frontend.onrender.com
DJANGO_SECURE_SSL_REDIRECT=1

# 2. Database (Supabase)
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres?sslmode=require

# 3. Redis (Required for Dashboard real-time/WebSockets)
# Render usually provides an INTERNAL_REDIS_URL if you create a Redis service
REDIS_URL=redis://your-redis-internal-url:6379

# 4. 🤖 Professional AI Parser
AI_PROVIDER=gemini  # or "openai"
AI_MODEL=gemini-1.5-flash
AI_API_KEY=your_ai_api_key_here

# 5. 📲 WhatsApp Business API (Meta)
WHATSAPP_TOKEN=your_meta_permanent_token_here
WHATSAPP_PHONE_ID=your_phone_number_id_here
WHATSAPP_VERIFY_TOKEN=create_a_unique_token_for_webhook_validation

# 6. Store Config
STORE_NAME=Minha Sorveteria
TIME_ZONE=America/Sao_Paulo
