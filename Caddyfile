(media_files) {
  handle_path /media/* {
    root * /srv/media
    header Cache-Control "public, max-age=2592000, stale-while-revalidate=86400"
    file_server
  }
}

http://{$API_DOMAIN} {
  encode zstd gzip
  import media_files
  handle {
    reverse_proxy backend:8000
  }
}

http://{$APP_DOMAIN} {
  encode zstd gzip
  handle /api/* {
    reverse_proxy backend:8000 {
      header_up Host {$API_DOMAIN}
    }
  }
  handle /ws/* {
    reverse_proxy backend:8000 {
      header_up Host {$API_DOMAIN}
    }
  }
  import media_files
  handle /health {
    reverse_proxy backend:8000 {
      header_up Host {$API_DOMAIN}
    }
  }
  handle {
    reverse_proxy frontend:80
  }
}

:80 {
  @local host 127.0.0.1 localhost
  handle @local {
    encode zstd gzip
    handle /api/* {
      reverse_proxy backend:8000
    }
    handle /ws/* {
      reverse_proxy backend:8000
    }
    import media_files
    handle /health {
      reverse_proxy backend:8000
    }
    handle {
      reverse_proxy frontend:80
    }
  }
}
