AGENT_HOST=127.0.0.1
AGENT_PORT=9876
PRINTER_MODE=escpos
PRINTER_VENDOR=generic

# PRINTER_CONN types: usb, net, win32, com
# win32 is best for Windows installed printers. Use PRINTER_NAME.
# com is best for virtual COM ports. Use PRINTER_COM_PORT.
# net is best for network printers. Use PRINTER_NET_HOST and PORT.
# usb is for generic USB (needs Zadig drivers).
PRINTER_CONN=win32
PRINTER_NAME="auto"
PRINTER_COM_PORT=COM4

PRINTER_NET_HOST=192.168.0.50
PRINTER_NET_PORT=9100
RECEIPT_WIDTH_MM=80

SCALE_ENABLED=true
SCALE_PORT=COM3
SCALE_BAUD=9600
SCALE_TIMEOUT_MS=800
SCALE_PROTOCOL=generic